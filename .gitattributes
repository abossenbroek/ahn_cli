# Store integration-test fixtures and vcrpy cassettes in git-LFS so binary
# point-cloud/raster fixtures and recorded HTTP interactions do not bloat the
# git history. See TODO.md "Full Integration Test Suite" (fixtures/cassettes
# live in git-LFS).
tests/**/fixtures/** filter=lfs diff=lfs merge=lfs -text
tests/**/cassettes/** filter=lfs diff=lfs merge=lfs -text
# Small text fixtures (feed XML, sample GeoJSON) are prose-sized, not the
# binary point-cloud/raster the rule above targets: keep them as normal git
# text so they diff/review inline and need no LFS upload.
tests/**/fixtures/*.xml !filter !diff !merge text
tests/**/fixtures/*.geojson !filter !diff !merge text
tests/**/fixtures/*.json !filter !diff !merge text
